{
  "name": "parallaxa-backend",
  "version": "1.0.0",
  "description": "Parallaxa - Independent Social Network Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node --watch src/index.ts --loader ts-node/esm",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:migrate": "node --loader ts-node/esm src/db/migrate.ts",
    "db:seed": "node --loader ts-node/esm src/db/seed.ts"
  },
  "keywords": [
    "social",
    "network",
    "api"
  ],
  "author": "Parallaxa Team",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.29.4",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.1.2",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.3",
    "drizzle-kit": "^0.20.14",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
